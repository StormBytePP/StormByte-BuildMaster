add_custom_command(
	OUTPUT "@_MESON_OUTPUT_LIBRARIES@"
	COMMAND @ENV_CMAKE_COMMAND@ -E echo "Installing @_CMAKE_COMPONENT_TITLE@"
	COMMAND @ENV_MESON_SILENT_COMMAND@ install -C @_MESON_BUILD_DIR@
	WORKING_DIRECTORY "@_MESON_BUILD_DIR@"
	BYPRODUCTS "@_MESON_OUTPUT_LIBRARIES@"
	DEPENDS @_MESON_STAGE_BUILD@
)

add_custom_target(
	@_MESON_STAGE_INSTALL
	DEPENDS "@_MESON_OUTPUT_LIBRARIES@"
)
