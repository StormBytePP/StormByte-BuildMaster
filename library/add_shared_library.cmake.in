include(@_LIBRARY_CONFIGURE_FILE@)
include(@_LIBRARY_BUILD_FILE@)
include(@_LIBRARY_INSTALL_FILE@)

add_library(@_LIBRARY_NAME@ SHARED IMPORTED GLOBAL)

if(MSVC)
	set_target_properties(@_LIBRARY_NAME@ PROPERTIES
		IMPORTED_IMPLIB "@_LIBRARY_FILE"
		IMPORTED_IMPLIB_DEBUG "@_LIBRARY_FILE"
		IMPORTED_IMPLIB_RELEASE "@_LIBRARY_FILE"
		IMPORTED_IMPLIB_MINSIZEREL "@_LIBRARY_FILE"
		IMPORTED_IMPLIB_RELWITHDEBINFO "@_LIBRARY_FILE"
	)
	set_target_properties(@_LIBRARY_NAME@ PROPERTIES
		IMPORTED_LOCATION "@_LIBRARY_DLL_FILE"
		IMPORTED_LOCATION_DEBUG "@_LIBRARY_DLL_FILE"
		IMPORTED_LOCATION_RELEASE "@_LIBRARY_DLL_FILE"
		IMPORTED_LOCATION_MINSIZEREL "@_LIBRARY_DLL_FILE"
		IMPORTED_LOCATION_RELWITHDEBINFO "@_LIBRARY_DLL_FILE"
	)
else()
	set_target_properties(@_LIBRARY_NAME@ PROPERTIES
		IMPORTED_LOCATION "@_LIBRARY_FILE"
		IMPORTED_LOCATION_DEBUG "@_LIBRARY_FILE"
		IMPORTED_LOCATION_RELEASE "@_LIBRARY_FILE"
		IMPORTED_LOCATION_MINSIZEREL "@_LIBRARY_FILE"
		IMPORTED_LOCATION_RELWITHDEBINFO "@_LIBRARY_FILE"
	)
endif()

add_dependencies(@_LIBRARY_NAME@ @_LIBRARY_STAGE_INSTALL)
